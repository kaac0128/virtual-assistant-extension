{
  "manifest_version": 3,
  "name": "Asistente IA Dark",
  "version": "1.0",
  "description": "Tu asistente virtual inteligente con diseño futurista.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Abrir Asistente"
  },
  "permissions": ["storage", "microphone", "activeTab"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentMain.js"],
      "css": ["client.css"]
    }
  ]
}
